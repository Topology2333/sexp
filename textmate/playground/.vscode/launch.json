{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Load Extension",
      "type": "extensionHost",
      "request": "launch",
      "runtimeExecutable": "${execPath}",
      "args": [
        "--extensionDevelopmentPath=${workspaceFolder}",
        "${workspaceFolder}/example.sexp"
      ],
      "autoAttachChildProcesses": true
    }
  ]
}