{
  "$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
  "name": "textmate",
  "scopeName": "source.textmate",
  "patterns": [
    {
      "name": "keyword.other",
      "match": "let|grammar|union|match|negative|repeat|concat|choice|surround"
    },
    {
      "name": "constant.numeric",
      "match": "\\d+"
    },
    {
      "name": "variable.name",
      "match": "[a-zA-Z_][a-zA-Z_0-9]*"
    },
    {
      "name": "string.quoted",
      "match": "\"[^\"]*\""
    }
  ]
}